// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================================================
// ENUMS
// ===================================================

enum TripStatus {
  DRAFT
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TripVisibility {
  PRIVATE
  PUBLIC
  SHARED
}

enum ActivityCategory {
  ADVENTURE
  FOOD
  CULTURE
  NATURE
  SHOPPING
  NIGHTLIFE
  SPORTS
  WELLNESS
  PHOTOGRAPHY
  OTHER
}

enum ActivityDifficulty {
  EASY
  MODERATE
  HARD
  EXTREME
}

enum ExpenseCategory {
  FLIGHTS
  HOTELS
  ACTIVITIES
  FOOD
  SHOPPING
  TRANSPORT
  VISA
  INSURANCE
  OTHER
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REFUNDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

// ===================================================
// RBAC — Roles & Permissions
// ===================================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  resource    String?
  action      String?
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ===================================================
// USERS
// ===================================================

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  passwordHash         String?
  name                 String
  avatar               String?
  bio                  String?
  phone                String?
  country              String?
  timezone             String?    @default("UTC")
  isEmailVerified      Boolean    @default(false)
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  status               UserStatus @default(ACTIVE)
  passwordResetToken   String?
  passwordResetExpires DateTime?
  refreshToken         String?
  googleId             String?    @unique
  lastLoginAt          DateTime?
  loginAttempts        Int        @default(0)
  lockUntil            DateTime?
  roleId               String
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  role          Role           @relation(fields: [roleId], references: [id])
  trips         Trip[]
  budgets       Budget[]
  subscriptions Subscription[]
  payments      Payment[]
  bookings      Booking[]
  tickets       SupportTicket[] @relation("UserTickets")
  assignedTickets SupportTicket[] @relation("AssignedTickets")
  packages      TravelPackage[] @relation("CreatedPackages")
  savedPackages PackageSave[]

  @@index([email])
  @@index([googleId])
  @@index([roleId])
  @@map("users")
}

// ===================================================
// GEOGRAPHY
// ===================================================

model Country {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  flag      String?
  continent String?
  createdAt DateTime @default(now())

  cities City[]

  @@map("countries")
}

model City {
  id          String   @id @default(uuid())
  name        String
  countryId   String
  latitude    Float?
  longitude   Float?
  images      String[]
  timezone    String?
  population  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  country      Country       @relation(fields: [countryId], references: [id])
  destinations Destination[]
  tripStops    TripStop[]

  @@unique([name, countryId])
  @@index([countryId])
  @@map("cities")
}

model Destination {
  id              String   @id @default(uuid())
  name            String
  description     String?
  cityId          String
  images          String[]
  coverImage      String?
  costIndex       Float?   @default(5.0)
  safetyIndex     Float?   @default(7.0)
  popularityScore Float?   @default(0.0)
  weatherData     Json?
  bestTimeToVisit String?
  tags            String[]
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  city       City       @relation(fields: [cityId], references: [id])
  activities Activity[]

  @@index([cityId])
  @@map("destinations")
}

// ===================================================
// ACTIVITIES
// ===================================================

model Activity {
  id            String             @id @default(uuid())
  name          String
  description   String?
  category      ActivityCategory   @default(OTHER)
  difficulty    ActivityDifficulty @default(EASY)
  durationHours Float?
  price         Float?             @default(0)
  currency      String             @default("USD")
  images        String[]
  tags          String[]
  destinationId String?
  isPublished   Boolean            @default(true)
  rating        Float?             @default(0)
  reviewCount   Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  destination Destination?    @relation(fields: [destinationId], references: [id])
  stopActivities TripStopActivity[]
  packageActivities PackageActivity[]

  @@index([destinationId])
  @@index([category])
  @@map("activities")
}

// ===================================================
// TRIPS
// ===================================================

model Trip {
  id          String         @id @default(uuid())
  userId      String
  name        String
  description String?
  coverImage  String?
  startDate   DateTime?
  endDate     DateTime?
  status      TripStatus     @default(DRAFT)
  visibility  TripVisibility @default(PRIVATE)
  shareToken  String?        @unique
  isArchived  Boolean        @default(false)
  tags        String[]
  aiData      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops   TripStop[]
  budgets Budget[]

  @@index([userId])
  @@index([status])
  @@map("trips")
}

model TripStop {
  id            String    @id @default(uuid())
  tripId        String
  cityId        String
  arrivalDate   DateTime?
  departureDate DateTime?
  order         Int       @default(0)
  notes         String?
  accommodation String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  trip       Trip               @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city       City               @relation(fields: [cityId], references: [id])
  activities TripStopActivity[]

  @@index([tripId])
  @@map("trip_stops")
}

model TripStopActivity {
  tripStopId String
  activityId String
  scheduledAt DateTime?
  notes       String?

  tripStop TripStop @relation(fields: [tripStopId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id])

  @@id([tripStopId, activityId])
  @@map("trip_stop_activities")
}

// ===================================================
// BUDGET & EXPENSES
// ===================================================

model Budget {
  id           String   @id @default(uuid())
  tripId       String
  userId       String
  totalAmount  Float
  spentAmount  Float    @default(0)
  currency     String   @default("USD")
  alertEnabled Boolean  @default(true)
  alertAt      Float?   @default(80)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])
  expenses Expense[]

  @@unique([tripId, userId])
  @@index([tripId])
  @@map("budgets")
}

model Expense {
  id          String          @id @default(uuid())
  budgetId    String
  category    ExpenseCategory @default(OTHER)
  amount      Float
  currency    String          @default("USD")
  description String?
  date        DateTime        @default(now())
  receipt     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@map("expenses")
}

// ===================================================
// SUBSCRIPTIONS & PAYMENTS
// ===================================================

model Subscription {
  id                String             @id @default(uuid())
  userId            String
  plan              SubscriptionPlan   @default(FREE)
  status            SubscriptionStatus @default(ACTIVE)
  startDate         DateTime           @default(now())
  endDate           DateTime?
  stripeCustomerId  String?
  stripeSubId       String?
  cancelAtPeriodEnd Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Payment {
  id              String        @id @default(uuid())
  userId          String
  amount          Float
  currency        String        @default("USD")
  status          PaymentStatus @default(PENDING)
  provider        String        @default("stripe")
  providerId      String?
  description     String?
  metadata        Json?
  createdAt       DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("payments")
}

// ===================================================
// TRAVEL PACKAGES & BOOKINGS
// ===================================================

model TravelPackage {
  id          String   @id @default(uuid())
  title       String
  description String?
  coverImage  String?
  images      String[]
  price       Float
  currency    String   @default("USD")
  durationDays Int
  maxGroupSize Int?
  includedItems String[]
  excludedItems String[]
  tags        String[]
  isPublished Boolean  @default(false)
  createdById String
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User              @relation("CreatedPackages", fields: [createdById], references: [id])
  activities  PackageActivity[]
  bookings    Booking[]
  saves       PackageSave[]

  @@index([createdById])
  @@map("travel_packages")
}

model PackageActivity {
  packageId  String
  activityId String
  dayNumber  Int?
  order      Int?

  package  TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  activity Activity      @relation(fields: [activityId], references: [id])

  @@id([packageId, activityId])
  @@map("package_activities")
}

model PackageSave {
  userId    String
  packageId String
  createdAt DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  package TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@id([userId, packageId])
  @@map("package_saves")
}

model Booking {
  id            String        @id @default(uuid())
  userId        String
  packageId     String
  status        BookingStatus @default(PENDING)
  totalAmount   Float
  currency      String        @default("USD")
  paymentStatus PaymentStatus @default(PENDING)
  travelDate    DateTime?
  groupSize     Int           @default(1)
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  package TravelPackage @relation(fields: [packageId], references: [id])

  @@index([userId])
  @@index([packageId])
  @@map("bookings")
}

// ===================================================
// SUPPORT
// ===================================================

model SupportTicket {
  id          String         @id @default(uuid())
  userId      String
  assignedTo  String?
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  resolution  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User  @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  assignee User? @relation("AssignedTickets", fields: [assignedTo], references: [id])

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

// ===================================================
// ANALYTICS
// ===================================================

model AnalyticsEvent {
  id         String   @id @default(uuid())
  eventType  String
  userId     String?
  resource   String?
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}
